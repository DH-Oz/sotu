    affiliation: Macquarie University
license: MIT
repository-code: "https://github.com/DH-Oz/sotu"
type: software
keywords:
  - state-of-the-union
  - digital-humanities
  - political-science
  - text-corpus
  - nlp
references:
  - type: database
    title: The American Presidency Project
    authors:
      - family-names: Peters
        given-names: Gerhard
      - family-names: Woolley
        given-names: John T.
    institution:
      name: University of California, Santa Barbara
    url: "https://www.presidency.ucsb.edu/"
    notes: >-
      The authoritative scholarly archive of presidential documents.
      All text content in the `sotu` Python package originates here.
      Please cite the American Presidency Project in any work that
      relies on this corpus.
  - type: software
    title: "sotu: R package for State of the Union Addresses"
    repository: "https://CRAN.R-project.org/package=sotu"
    notes: >-
      The R `sotu` CRAN package established the classification rules
      (sotu_type, party assignments) that this Python package adopts.
